.mcp.json
.claude/
.claude/settings.local.json
.idea/
.stack-work/
dist-newstyle/
dist/
plans/
.test-cache/
.test-images/
# Python tool caches
.ruff_cache/
.mypy_cache/
# Root-level editable-install metadata (the unified distribution
# lives at the repo root, so its .egg-info lands there too).
*.egg-info/
# Python extension build artefacts
python/.venv*/
python/corvus_client/_corvus.abi3.so
python/corvus_client/_generated.py
python/**/__pycache__/
python/.pytest_cache/
python/**/*.egg-info/
# Integration test suite build artefacts
integration_tests/.venv*/
integration_tests/.pytest_cache/
integration_tests/**/__pycache__/
integration_tests/**/*.egg-info/
# Shared SSH keypair embedded in test images (generated by `make test-image-key`)
integration_tests/keys/
# Synthetic-installer build cache + intermediates (generated by
# scripts/build-synthetic-installer.sh; the final .raw lives under
# ~/VMs/BaseImages/SyntheticInstaller/ and is not in-tree).
build/
release/
# Frontend (vite) build outputs. The repo keeps source under frontend/;
# build artefacts (frontend/dist and the staged copy under
# python/corvus_web/static/) are produced by `make web-build` and
# shipped only inside the Python wheel.
frontend/node_modules/
frontend/dist/
# tsc -b emits incremental-build state plus a compiled vite.config.{js,d.ts}
# alongside the source — none of which is shipped or imported anywhere.
frontend/*.tsbuildinfo
frontend/vite.config.js
frontend/vite.config.d.ts
python/corvus_web/static/*
!python/corvus_web/static/.gitkeep
