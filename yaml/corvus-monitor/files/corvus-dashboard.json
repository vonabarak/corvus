{
  "uid": "corvus-overview",
  "title": "Corvus Overview",
  "tags": ["corvus"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "templating": {"list": []},
  "annotations": {"list": []},
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "VMs Up",
      "description": "Count of VMs reporting a fresh stats sample within the last 60 s.",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum(corvus_vm_up)", "legendFormat": "up"}
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "VM up/down over time",
      "description": "Per-VM liveness. A drop to 0 = stats sample stale > 60 s (likely agent or daemon trouble).",
      "gridPos": {"x": 6, "y": 0, "w": 18, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "corvus_vm_up", "legendFormat": "{{vm_name}}"}
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 25,
            "lineWidth": 1,
            "showPoints": "never",
            "stacking": {"mode": "none"}
          },
          "min": 0,
          "max": 1,
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "none"}
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Per-VM CPU rate",
      "description": "Cumulative vCPU thread seconds per second (= effective cores used).",
      "gridPos": {"x": 0, "y": 4, "w": 24, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "rate(corvus_vm_cpu_seconds_total[5m])",
          "legendFormat": "{{vm_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never",
            "stacking": {"mode": "none"}
          },
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Per-VM host RSS",
      "description": "QEMU process RSS on the host (corvus_vm_memory_rss_bytes).",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "corvus_vm_memory_rss_bytes", "legendFormat": "{{vm_name}}"}
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never",
            "stacking": {"mode": "none"}
          },
          "unit": "bytes",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Per-VM balloon (guest-visible RAM)",
      "description": "0 for VMs without a balloon device.",
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "corvus_vm_memory_balloon_actual_bytes", "legendFormat": "{{vm_name}}"}
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never",
            "stacking": {"mode": "none"}
          },
          "unit": "bytes",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Disk read",
      "description": "Per-drive read throughput.",
      "gridPos": {"x": 0, "y": 20, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "rate(corvus_vm_disk_read_bytes_total[1m])",
          "legendFormat": "{{vm_name}} / {{drive}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never",
            "stacking": {"mode": "none"}
          },
          "unit": "Bps",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Disk write",
      "description": "Per-drive write throughput.",
      "gridPos": {"x": 12, "y": 20, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "rate(corvus_vm_disk_write_bytes_total[1m])",
          "legendFormat": "{{vm_name}} / {{drive}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never",
            "stacking": {"mode": "none"}
          },
          "unit": "Bps",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Network RX",
      "description": "Per-TAP receive throughput.",
      "gridPos": {"x": 0, "y": 28, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "rate(corvus_vm_net_rx_bytes_total[1m])",
          "legendFormat": "{{vm_name}} / {{tap}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never",
            "stacking": {"mode": "none"}
          },
          "unit": "Bps",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Network TX",
      "description": "Per-TAP transmit throughput.",
      "gridPos": {"x": 12, "y": 28, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "rate(corvus_vm_net_tx_bytes_total[1m])",
          "legendFormat": "{{vm_name}} / {{tap}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never",
            "stacking": {"mode": "none"}
          },
          "unit": "Bps",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Node load (1-min avg)",
      "description": "Per-node 1-minute load average.",
      "gridPos": {"x": 0, "y": 36, "w": 8, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "corvus_node_load1", "legendFormat": "{{node}}"}
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never",
            "stacking": {"mode": "none"}
          },
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 11,
      "type": "bargauge",
      "title": "Node memory free",
      "description": "Free RAM / total RAM per node.",
      "gridPos": {"x": 8, "y": 36, "w": 8, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "corvus_node_memory_free_bytes / corvus_node_memory_total_bytes",
          "legendFormat": "{{node}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.1},
              {"color": "green", "value": 0.25}
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true,
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      }
    },
    {
      "id": 12,
      "type": "bargauge",
      "title": "Node storage free",
      "description": "Free storage / total storage on each node's basePath filesystem.",
      "gridPos": {"x": 16, "y": 36, "w": 8, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "corvus_node_storage_free_bytes / corvus_node_storage_total_bytes",
          "legendFormat": "{{node}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.1},
              {"color": "green", "value": 0.25}
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true,
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      }
    }
  ]
}
