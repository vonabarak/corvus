<?xml version="1.0" encoding="utf-8"?>
<unattend xmlns="urn:schemas-microsoft-com:unattend">
  <settings pass="windowsPE">
    <component name="Microsoft-Windows-International-Core-WinPE" processorArchitecture="amd64" publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS" xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
      <SetupUILanguage>
        <UILanguage>en-US</UILanguage>
      </SetupUILanguage>
      <InputLocale>en-US</InputLocale>
      <SystemLocale>en-US</SystemLocale>
      <UILanguage>en-US</UILanguage>
      <UserLocale>en-US</UserLocale>
    </component>
    <component name="Microsoft-Windows-PnpCustomizationsWinPE" processorArchitecture="amd64" publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS" xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
      <DriverPaths>
        <PathAndCredentials wcm:action="add" wcm:keyValue="1">
          <Path>E:\vioserial\2k25\amd64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="2">
          <Path>E:\viostor\2k25\amd64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="3">
          <Path>E:\NetKVM\2k25\amd64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="4">
          <Path>E:\qemufwcfg\2k25\amd64</Path>
        </PathAndCredentials>
      </DriverPaths>
    </component>
    <component name="Microsoft-Windows-Setup" processorArchitecture="amd64" publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS" xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
      <DiskConfiguration>
        <Disk wcm:action="add">
          <CreatePartitions>
            <CreatePartition wcm:action="add">
              <Order>1</Order>
              <Type>EFI</Type>
              <Size>100</Size>
            </CreatePartition>
            <CreatePartition wcm:action="add">
              <Order>2</Order>
              <Type>MSR</Type>
              <Size>16</Size>
            </CreatePartition>
            <CreatePartition wcm:action="add">
              <Order>3</Order>
              <Type>Primary</Type>
              <Extend>true</Extend>
            </CreatePartition>
          </CreatePartitions>
          <ModifyPartitions>
            <ModifyPartition wcm:action="add">
              <Order>1</Order>
              <PartitionID>1</PartitionID>
              <Format>FAT32</Format>
              <Label>System</Label>
            </ModifyPartition>
            <ModifyPartition wcm:action="add">
              <Order>2</Order>
              <PartitionID>2</PartitionID>
            </ModifyPartition>
            <ModifyPartition wcm:action="add">
              <Order>3</Order>
              <PartitionID>3</PartitionID>
              <Format>NTFS</Format>
              <Label>Windows</Label>
            </ModifyPartition>
          </ModifyPartitions>
          <DiskID>0</DiskID>
          <WillWipeDisk>true</WillWipeDisk>
        </Disk>
      </DiskConfiguration>
      <ImageInstall>
        <OSImage>
          <InstallFrom>
            <MetaData wcm:action="add">
              <!-- Index 2 = "Windows Server 2025 Standard Evaluation (Desktop Experience)" -->
              <Key>/IMAGE/INDEX</Key>
              <Value>2</Value>
            </MetaData>
          </InstallFrom>
          <InstallTo>
            <DiskID>0</DiskID>
            <PartitionID>3</PartitionID>
          </InstallTo>
          <InstallToAvailablePartition>false</InstallToAvailablePartition>
        </OSImage>
      </ImageInstall>
      <UserData>
        <AcceptEula>true</AcceptEula>
      </UserData>
    </component>
  </settings>
  <settings pass="specialize">
    <component name="Microsoft-Windows-Shell-Setup" processorArchitecture="amd64" publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS" xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
      <ComputerName>corvus-win</ComputerName>
      <TimeZone>UTC</TimeZone>
    </component>
  </settings>
  <settings pass="oobeSystem">
    <component name="Microsoft-Windows-Shell-Setup" processorArchitecture="amd64" publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS" xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
      <AutoLogon>
        <Password>
          <Value>corvus</Value>
          <PlainText>true</PlainText>
        </Password>
        <Enabled>true</Enabled>
        <Username>corvus</Username>
      </AutoLogon>
      <FirstLogonCommands>
        <SynchronousCommand wcm:action="add">
          <CommandLine>powershell -Command "Set-ExecutionPolicy Bypass -Force"</CommandLine>
          <Order>1</Order>
        </SynchronousCommand>
        <SynchronousCommand wcm:action="add">
          <CommandLine>powershell -Command "Start-Process msiexec -ArgumentList '/i','E:\guest-agent\qemu-ga-x86_64.msi','/qn' -Wait"</CommandLine>
          <Order>2</Order>
        </SynchronousCommand>
        <SynchronousCommand wcm:action="add">
          <CommandLine>powershell -Command "Start-Service QEMU-GA"</CommandLine>
          <Order>3</Order>
        </SynchronousCommand>
        <SynchronousCommand wcm:action="add">
          <CommandLine>powershell -Command "Invoke-WebRequest -Uri 'https://cloudbase.it/downloads/CloudbaseInitSetup_Stable_x64.msi' -OutFile 'C:\Windows\Temp\CloudbaseInit.msi'"</CommandLine>
          <Order>4</Order>
        </SynchronousCommand>
        <SynchronousCommand wcm:action="add">
          <CommandLine>powershell -Command "Start-Process msiexec -ArgumentList '/i','C:\Windows\Temp\CloudbaseInit.msi','/qn','/l*v','C:\Windows\Temp\cloudbase-init.log','USERNAME=Administrator','LOGGINGSERIALPORTNAME=COM1' -Wait"</CommandLine>
          <Order>5</Order>
        </SynchronousCommand>
        <SynchronousCommand wcm:action="add">
          <CommandLine>powershell -Command "Remove-Item 'C:\Windows\Temp\CloudbaseInit.msi' -Force -ErrorAction SilentlyContinue"</CommandLine>
          <Order>6</Order>
        </SynchronousCommand>
        <SynchronousCommand wcm:action="add">
          <CommandLine>powershell -Command "Add-Content -Path 'C:\Program Files\Cloudbase Solutions\Cloudbase-Init\conf\cloudbase-init.conf' -Value @('metadata_services=cloudbaseinit.metadata.services.nocloudservice.NoCloudConfigDriveService','first_logon_behaviour=no')"</CommandLine>
          <Order>7</Order>
        </SynchronousCommand>
        <!-- WinFSP — user-mode file system framework that the virtio-fs
             Windows driver depends on. Pinned to v2.1 (the current
             stable as of 2025-05). -->
        <SynchronousCommand wcm:action="add">
          <CommandLine>powershell -Command "Invoke-WebRequest -Uri 'https://github.com/winfsp/winfsp/releases/download/v2.1/winfsp-2.1.25156.msi' -OutFile 'C:\Windows\Temp\winfsp.msi'"</CommandLine>
          <Order>8</Order>
        </SynchronousCommand>
        <SynchronousCommand wcm:action="add">
          <CommandLine>powershell -Command "Start-Process msiexec -ArgumentList '/i','C:\Windows\Temp\winfsp.msi','/qn' -Wait"</CommandLine>
          <Order>9</Order>
        </SynchronousCommand>
        <!-- virtio-fs guest driver — already on E:\ (the virtio-win
             ISO is still mounted during install). The 2k25 variant
             matches Windows Server 2025. `pnputil /add-driver`
             registers the kernel driver in the driver store so
             Windows binds it when the virtio-fs PCI device shows
             up; on its own it does NOT create the VirtioFsSvc
             user-mode service — that requires running virtiofs.exe
             with `-i`. -->
        <SynchronousCommand wcm:action="add">
          <CommandLine>powershell -Command "pnputil /add-driver E:\viofs\2k25\amd64\viofs.inf /install"</CommandLine>
          <Order>10</Order>
        </SynchronousCommand>
        <!-- Copy the user-mode viofs binary to a persistent location.
             `virtiofs.exe -i` will register a Windows service whose
             ImagePath is the path of the binary that ran the install,
             so it has to live somewhere that survives a reboot — E:\
             is the virtio-win ISO and won't be present at next boot. -->
        <SynchronousCommand wcm:action="add">
          <CommandLine>cmd /c mkdir "C:\Program Files\Virtio-FS"</CommandLine>
          <Order>11</Order>
        </SynchronousCommand>
        <SynchronousCommand wcm:action="add">
          <CommandLine>cmd /c copy /Y E:\viofs\2k25\amd64\virtiofs.exe "C:\Program Files\Virtio-FS\virtiofs.exe"</CommandLine>
          <Order>12</Order>
        </SynchronousCommand>
        <!-- Register the VirtioFsSvc Windows service. The naive way is
             `virtiofs.exe -i`, but that command both REGISTERS and
             STARTS the service in one step, and the service then
             blocks waiting for the virtio-fs PCI device — which isn't
             attached during the bake, so the SynchronousCommand
             never returns and the bake hangs forever on the splash
             "The VirtIO-FS service will start and wait for the device".
             Use PowerShell's `New-Service` instead: it only creates
             the SCM entry (no service start), and `-StartupType
             Automatic` ensures it starts on the *next* boot — by
             which time the harness has attached the virtio-fs device.
             Pre-encoded as -EncodedCommand to dodge the cmd.exe/
             autounattend quote-escaping mess around the space in
             "Program Files". Decodes to:
               New-Service -Name VirtioFsSvc
                           -BinaryPathName '"C:\Program Files\Virtio-FS\virtiofs.exe"'
                           -StartupType Automatic
                           -DisplayName 'VirtIO-FS Service'
        -->
        <SynchronousCommand wcm:action="add">
          <CommandLine>powershell -EncodedCommand </CommandLine>
          <Order>13</Order>
        </SynchronousCommand>
        <SynchronousCommand wcm:action="add">
          <CommandLine>shutdown /s /t 30 /f</CommandLine>
          <Order>14</Order>
        </SynchronousCommand>
      </FirstLogonCommands>
      <OOBE>
        <HideEULAPage>true</HideEULAPage>
        <HideLocalAccountScreen>true</HideLocalAccountScreen>
        <HideOEMRegistrationScreen>true</HideOEMRegistrationScreen>
        <HideOnlineAccountScreens>true</HideOnlineAccountScreens>
        <HideWirelessSetupInOOBE>true</HideWirelessSetupInOOBE>
        <ProtectYourPC>3</ProtectYourPC>
        <SkipMachineOOBE>true</SkipMachineOOBE>
        <SkipUserOOBE>true</SkipUserOOBE>
      </OOBE>
      <UserAccounts>
        <LocalAccounts>
          <LocalAccount wcm:action="add">
            <Password>
              <Value>corvus</Value>
              <PlainText>true</PlainText>
            </Password>
            <DisplayName>corvus</DisplayName>
            <Group>Administrators</Group>
            <Name>corvus</Name>
          </LocalAccount>
        </LocalAccounts>
      </UserAccounts>
    </component>
  </settings>
</unattend>
